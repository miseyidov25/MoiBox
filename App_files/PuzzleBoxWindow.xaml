<Window x:Class="PuzzleBoxApp.PuzzleBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puzzle Box - iBeacon Detector" Height="600" Width="800">
    <Grid Background="#F0F0F0">
        <StackPanel Margin="20">
            <TextBlock Text="Puzzle Box - iBeacon Detector" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <GroupBox Header="Detected Beacons" Margin="0,0,0,10">
                <ListBox x:Name="BeaconListBox" Height="100"/>
            </GroupBox>
            
            <GroupBox Header="Current Puzzle">
                <StackPanel>
                    <TextBlock x:Name="PuzzleNameLabel" FontSize="18" FontWeight="Bold" Margin="0,10"/>
                    <TextBlock x:Name="DifficultyLabel" Margin="0,5"/>
                    <TextBox x:Name="PuzzleContentTextBox" Height="200" 
                             TextWrapping="Wrap" IsReadOnly="True" Margin="0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Submit Answer" Padding="10,5" Margin="5"/>
                        <Button Content="Skip Puzzle" Padding="10,5" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>